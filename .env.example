ENVIRONMENT=local
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]

# SEC asks automated clients to identify themselves.
# Use your real name and email for serious use.
SEC_USER_AGENT="Your Name your.email@example.com"
SEC_METADATA_CACHE_SECONDS=21600
SEC_RATE_LIMIT_RETRIES=2
SEC_RATE_LIMIT_RETRY_SECONDS=2

SQLITE_PATH=data/sec_sentiment.db
MAX_FILING_CHARS=1000000

# Use "template" for no-key local explanations, "openai" for LLM explanations,
# or "none" to return only scores and evidence.
EXPLANATION_PROVIDER=template
LLM_MAX_EVIDENCE_EXCERPTS=8

# Required only when EXPLANATION_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
